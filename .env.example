# Agent Academy Lab Tester — Environment Configuration
# Copy this file to .env and fill in your values.
# The .env file is gitignored and never committed.

# Your Copilot Studio environment URL (required)
# Find this by opening Copilot Studio and copying the URL from the address bar
AGENT_ACADEMY_ENV_URL=https://copilotstudio.microsoft.com/environments/YOUR-ENVIRONMENT-ID/home

# Your Edge profile path (optional — defaults to the system default profile)
# Find yours at edge://version in the profile you want to use
EDGE_PROFILE_PATH=~/Library/Application Support/Microsoft Edge/Profile 39
