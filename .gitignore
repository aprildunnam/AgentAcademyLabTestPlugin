# Plugin runtime state — never committed.
# This directory holds:
#   - account/credential.enc      DPAPI-encrypted workshop-account credentials (user-scoped)
#   - account/account.meta.json   cached account metadata (user_id, timestamps)
#   - audit-history.yml           rolling local log of every audit run
#   - runs/<run-id>/...           per-run parsed steps, findings, screenshots, transcripts
# All of it is local, user-specific, and frequently contains secrets or PII. Never commit.
runtime/

# OS / editor / IDE artifacts
.DS_Store
Thumbs.db
*.swp
*.swo
.vscode/
.idea/

# Temporary working directories
.repo-inspect/
*.tmp
