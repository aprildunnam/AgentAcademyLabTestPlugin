# Environment-specific config (contains personal environment IDs)
.env

# Plugin runtime state — never committed.
# This directory holds:
#   - test-results/         per-run test reports and findings
#   - screenshots/          annotated and clean screenshots
#   - rewrites/             rewritten lab output from /rewrite-lab
#   - new-labs/             new lab output from /create-lab
#   - solutions/            exported solution .zip files
#   - cleanup/              cleanup reports
# All of it is local and user-specific. Never commit.
runtime/

# OS / editor / IDE artifacts
.DS_Store
Thumbs.db
*.swp
*.swo
.vscode/
.idea/

# Temporary working directories
.repo-inspect/
*.tmp
tests/fixtures/
